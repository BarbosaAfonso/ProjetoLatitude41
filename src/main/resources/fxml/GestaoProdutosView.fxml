<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1000.0" styleClass="gestao-root"
            stylesheets="@/css/gestao-produtos.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.gestao_restaurante.Views.GestaoProdutosScreen">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="gestao-toolbar-card" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="18.0" left="20.0" right="20.0" top="20.0"/>
            </padding>
            <children>
                <VBox prefWidth="430.0" spacing="6.0" styleClass="toolbar-copy">
                    <children>
                        <Label styleClass="toolbar-caption" text="Pesquisa e acoes rapidas"/>
                        <Label styleClass="toolbar-hint" text="Procura por nome, tipo, preco e disponibilidade."/>
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="pesquisaField" onKeyReleased="#onPesquisar" promptText="Pesquisar produtos..." styleClass="pesquisa-field"/>
                <Button fx:id="btnNovoProduto" mnemonicParsing="false" onAction="#onNovoProduto" styleClass="novo-produto-button" text="+ Novo Produto"/>
            </children>
        </HBox>
    </top>
    <center>
        <VBox spacing="14.0" styleClass="table-shell" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets left="20.0" right="20.0" top="18.0"/>
            </BorderPane.margin>
            <padding>
                <Insets bottom="26.0" left="0.0" right="0.0" top="0.0"/>
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="table-controls-row">
                    <children>
                        <FlowPane fx:id="filtrosCategoriaBox" hgap="8.0" vgap="8.0"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Label styleClass="control-label" text="Ordenar por"/>
                                <ComboBox fx:id="ordenarPorCombo" onAction="#onOrdenacaoAlterada" prefWidth="170.0" styleClass="table-control-combo"/>
                                <ComboBox fx:id="direcaoOrdenacaoCombo" onAction="#onOrdenacaoAlterada" prefWidth="120.0" styleClass="table-control-combo"/>
                            </children>
                        </HBox>
                    </children>
                </HBox>
                <TableView fx:id="tabela" styleClass="produtos-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="80.0" text="ID"/>
                        <TableColumn fx:id="colNome" prefWidth="220.0" text="Nome"/>
                        <TableColumn fx:id="colTipo" prefWidth="170.0" text="Tipo"/>
                        <TableColumn fx:id="colPreco" prefWidth="130.0" text="Preco"/>
                        <TableColumn fx:id="colDisponivel" prefWidth="160.0" text="Disponibilidade"/>
                        <TableColumn fx:id="colAcoes" prefWidth="140.0" text="Acoes"/>
                    </columns>
                </TableView>
            </children>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="18.0" left="20.0" right="20.0" top="10.0"/>
            </padding>
            <children>
                <Button mnemonicParsing="false" onAction="#onVoltar" styleClass="voltar-button" text="Voltar"/>
            </children>
        </HBox>
    </bottom>
</BorderPane>
