<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="main-shell"
            stylesheets="@/css/menu-principal.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.gestao_restaurante.Views.MenuPrincipalScreen">

    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" styleClass="dashboard-scroll" BorderPane.alignment="CENTER">
            <content>
                <VBox fillWidth="true" spacing="18.0" styleClass="dashboard-content">
                    <padding>
                        <Insets bottom="24.0" left="26.0" right="26.0" top="26.0"/>
                    </padding>
                    <children>
                        <GridPane hgap="16.0" vgap="16.0">
                            <columnConstraints>
                                <ColumnConstraints fillWidth="true" hgrow="ALWAYS" percentWidth="50.0" />
                                <ColumnConstraints fillWidth="true" hgrow="ALWAYS" percentWidth="50.0" />
                            </columnConstraints>
                            <children>
                                <VBox maxWidth="1.7976931348623157E308" styleClass="kpi-card" GridPane.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="kpi-title" text="Produtos Ativos"/>
                                        <Label fx:id="kpiProdutosValue" styleClass="kpi-value" text="--"/>
                                        <Label fx:id="kpiProdutosSub" styleClass="kpi-sub" text="--"/>
                                    </children>
                                </VBox>

                                <VBox maxWidth="1.7976931348623157E308" styleClass="kpi-card" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="kpi-title" text="Reservas Hoje"/>
                                        <Label fx:id="kpiReservasValue" styleClass="kpi-value" text="--"/>
                                        <Label fx:id="kpiReservasSub" styleClass="kpi-sub" text="--"/>
                                    </children>
                                </VBox>

                                <VBox maxWidth="1.7976931348623157E308" styleClass="kpi-card" GridPane.hgrow="ALWAYS" GridPane.rowIndex="1">
                                    <children>
                                        <Label styleClass="kpi-title" text="Pedidos em Curso"/>
                                        <Label fx:id="kpiPedidosValue" styleClass="kpi-value" text="--"/>
                                        <Label fx:id="kpiPedidosSub" styleClass="kpi-sub" text="--"/>
                                    </children>
                                </VBox>

                                <VBox maxWidth="1.7976931348623157E308" styleClass="kpi-card" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS" GridPane.rowIndex="1">
                                    <children>
                                        <Label styleClass="kpi-title" text="Ocupacao Mesas"/>
                                        <Label fx:id="kpiOcupacaoValue" styleClass="kpi-value" text="--"/>
                                        <Label fx:id="kpiOcupacaoSub" styleClass="kpi-sub" text="--"/>
                                    </children>
                                </VBox>
                            </children>
                        </GridPane>

                        <HBox spacing="16.0">
                            <children>
                                <VBox spacing="8.0" styleClass="panel-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="panel-title" text="Estado de Mesas"/>
                                        <Label fx:id="mesasResumoLabel" styleClass="panel-text" text="A carregar..."/>
                                    </children>
                                </VBox>

                                <VBox spacing="8.0" styleClass="panel-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="panel-title" text="Resumo Operacional"/>
                                        <Label fx:id="resumoOperacionalLabel" styleClass="panel-text" text="A carregar..."/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
