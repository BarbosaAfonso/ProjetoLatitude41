<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1000.0" styleClass="gestao-root"
            stylesheets="@/css/gestao-produtos.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.gestao_restaurante.Views.GestaoUtilizadoresScreen">
    <top>
        <VBox spacing="16.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="floor-header" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets bottom="14.0" left="24.0" right="24.0" top="20.0"/>
                    </padding>
                    <children>
                        <VBox spacing="3.0">
                            <children>
                                <Label styleClass="floor-title" text="Utilizadores"/>
                                <Label fx:id="sessaoLabel" styleClass="floor-subtitle" text="Sessao da Noite"/>
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <children>
                                <VBox alignment="CENTER_RIGHT" spacing="1.0">
                                    <children>
                                        <Label fx:id="utilizadorLabel" styleClass="user-name" text="Admin"/>
                                        <Label fx:id="cargoLabel" styleClass="user-role" text="ADMINISTRADOR"/>
                                    </children>
                                </VBox>

                                <StackPane styleClass="user-avatar">
                                    <children>
                                        <Label fx:id="avatarLabel" styleClass="user-avatar-text" text="A"/>
                                    </children>
                                </StackPane>

                                <Label styleClass="header-pill" text="ADMIN"/>
                                <Label styleClass="header-pill" text="PERFIS"/>
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="gestao-toolbar-card" BorderPane.alignment="CENTER">
                    <padding>
                        <Insets bottom="0.0" left="20.0" right="20.0" top="0.0"/>
                    </padding>
                    <children>
                        <VBox spacing="2.0">
                            <children>
                                <Label styleClass="toolbar-caption" text="Pesquisa e administracao"/>
                                <Label styleClass="toolbar-hint" text="Atualiza cargos, desativa contas e reativa colaboradores."/>
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="pesquisaField" onKeyReleased="#onPesquisar" promptText="Pesquisar utilizadores..." styleClass="pesquisa-field"/>
                        <Button mnemonicParsing="false" onAction="#onAdicionar" styleClass="novo-registo-button" text="+ Nova Conta"/>
                        <Button mnemonicParsing="false" onAction="#onAtualizar" styleClass="novo-registo-button" text="Atualizar"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>
    <center>
        <VBox styleClass="table-shell" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="26.0" left="20.0" right="20.0" top="18.0"/>
            </padding>
            <children>
                <TableView fx:id="tabela" styleClass="gestao-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="70.0" text="ID"/>
                        <TableColumn fx:id="colNome" prefWidth="220.0" text="Nome"/>
                        <TableColumn fx:id="colEmail" prefWidth="250.0" text="Email"/>
                        <TableColumn fx:id="colTipo" prefWidth="150.0" text="Tipo"/>
                        <TableColumn fx:id="colEstadoConta" prefWidth="150.0" text="Estado"/>
                        <TableColumn fx:id="colAcoes" prefWidth="220.0" text="Acoes"/>
                    </columns>
                </TableView>
            </children>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="18.0" left="20.0" right="20.0" top="10.0"/>
            </padding>
            <children>
                <Button mnemonicParsing="false" onAction="#onVoltar" styleClass="voltar-button" text="Voltar"/>
            </children>
        </HBox>
    </bottom>
</BorderPane>
