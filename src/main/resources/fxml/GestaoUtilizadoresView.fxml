<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1000.0" styleClass="gestao-root"
            stylesheets="@/css/gestao-produtos.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.gestao_restaurante.Views.GestaoUtilizadoresScreen">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="gestao-toolbar-card" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="18.0" left="20.0" right="20.0" top="20.0"/>
            </padding>
            <children>
                <VBox prefWidth="520.0" spacing="6.0" styleClass="toolbar-copy">
                    <children>
                        <Label styleClass="toolbar-caption" text="Pesquisa e administracao"/>
                        <Label styleClass="toolbar-hint" text="Atualiza cargos, desativa contas e reativa colaboradores."/>
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="pesquisaField" onKeyReleased="#onPesquisar" promptText="Pesquisar utilizadores..." styleClass="pesquisa-field"/>
                <Button mnemonicParsing="false" onAction="#onAdicionar" styleClass="novo-registo-button" text="+ Nova Conta"/>
                <Button mnemonicParsing="false" onAction="#onAtualizar" styleClass="novo-registo-button" text="Atualizar"/>
            </children>
        </HBox>
    </top>
    <center>
        <VBox styleClass="table-shell" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets left="20.0" right="20.0" top="18.0"/>
            </BorderPane.margin>
            <padding>
                <Insets bottom="26.0" left="0.0" right="0.0" top="0.0"/>
            </padding>
            <children>
                <TableView fx:id="tabela" styleClass="gestao-table" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colId" minWidth="50.0" prefWidth="50.0" maxWidth="50.0" text="ID"/>
                        <TableColumn fx:id="colNome" minWidth="180.0" prefWidth="280.0" text="Nome"/>
                        <TableColumn fx:id="colEmail" minWidth="230.0" prefWidth="360.0" text="Email"/>
                        <TableColumn fx:id="colTipo" minWidth="150.0" prefWidth="150.0" maxWidth="150.0" text="Tipo"/>
                        <TableColumn fx:id="colEstadoConta" minWidth="130.0" prefWidth="130.0" maxWidth="130.0" text="Estado"/>
                        <TableColumn fx:id="colAcoes" minWidth="190.0" prefWidth="190.0" maxWidth="190.0" text="Acoes"/>
                    </columns>
                </TableView>
            </children>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="18.0" left="20.0" right="20.0" top="10.0"/>
            </padding>
            <children>
                <Button mnemonicParsing="false" onAction="#onVoltar" styleClass="voltar-button" text="Voltar"/>
            </children>
        </HBox>
    </bottom>
</BorderPane>
