<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1000.0" styleClass="gestao-root"
            stylesheets="@/css/gestao-produtos.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.gestao_restaurante.Views.GestaoStockScreen">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="gestao-toolbar-card" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="0.0" left="20.0" right="20.0" top="20.0"/>
            </padding>
            <children>
                <VBox spacing="2.0">
                    <children>
                        <Label styleClass="toolbar-caption" text="Pesquisa e encomendas"/>
                        <Label styleClass="toolbar-hint" text="Regista pedidos ao fornecedor e confirma a chegada dos ingredientes."/>
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="pesquisaField" onKeyReleased="#onPesquisar" promptText="Pesquisar stock..." styleClass="pesquisa-field"/>
                <Button fx:id="btnNovoStock" mnemonicParsing="false" onAction="#onNovoStock" styleClass="novo-registo-button" text="+ Nova Encomenda"/>
            </children>
        </HBox>
    </top>
    <center>
        <VBox styleClass="table-shell" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="26.0" left="20.0" right="20.0" top="18.0"/>
            </padding>
            <children>
                <TableView fx:id="tabela" styleClass="gestao-table" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colId" minWidth="120.0" prefWidth="120.0" maxWidth="120.0" text="ID Ingrediente"/>
                        <TableColumn fx:id="colIngrediente" minWidth="240.0" prefWidth="360.0" text="Ingrediente"/>
                        <TableColumn fx:id="colQuant" minWidth="150.0" prefWidth="170.0" maxWidth="170.0" text="Quantidade"/>
                        <TableColumn fx:id="colEstado" minWidth="150.0" prefWidth="170.0" maxWidth="170.0" text="Estado"/>
                        <TableColumn fx:id="colAcoes" minWidth="140.0" prefWidth="160.0" maxWidth="160.0" text="Acoes"/>
                    </columns>
                </TableView>
            </children>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="18.0" left="20.0" right="20.0" top="10.0"/>
            </padding>
            <children>
                <Button mnemonicParsing="false" onAction="#onVoltar" styleClass="voltar-button" text="Voltar"/>
            </children>
        </HBox>
    </bottom>
</BorderPane>
