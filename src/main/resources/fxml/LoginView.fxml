<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="login-root" stylesheets="@../css/login.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.gestao_restaurante.Views.LoginScreen">
    <children>
        <Region maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="login-overlay" />

        <Region prefHeight="240.0" prefWidth="210.0" styleClass="blob blob-top-right" StackPane.alignment="TOP_RIGHT">
            <StackPane.margin>
                <Insets right="60.0" top="78.0" />
            </StackPane.margin>
        </Region>
        <Region prefHeight="220.0" prefWidth="200.0" styleClass="blob blob-mid-left" StackPane.alignment="CENTER_LEFT">
            <StackPane.margin>
                <Insets left="58.0" top="70.0" />
            </StackPane.margin>
        </Region>
        <Region prefHeight="240.0" prefWidth="210.0" styleClass="blob blob-bottom-right" StackPane.alignment="BOTTOM_RIGHT">
            <StackPane.margin>
                <Insets bottom="70.0" right="84.0" />
            </StackPane.margin>
        </Region>

        <StackPane alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308">
            <children>
                <VBox alignment="CENTER" fillWidth="true" maxWidth="460.0" spacing="22.0">
                    <children>
                        <VBox alignment="CENTER" spacing="4.0">
                            <children>
                                <Label styleClass="brand-title" text="Latitude 41" />
                                <Label styleClass="brand-subtitle" text="STAFF PORTAL" />
                            </children>
                        </VBox>

                        <VBox fillWidth="true" maxWidth="420.0" spacing="20.0" styleClass="login-card">
                            <padding>
                                <Insets bottom="30.0" left="34.0" right="34.0" top="30.0" />
                            </padding>
                            <children>
                                <VBox spacing="6.0" styleClass="input-group">
                                    <children>
                                        <Label styleClass="field-label" text="ID DE FUNCIONARIO" />
                                        <TextField fx:id="emailField" maxWidth="1.7976931348623157E308" promptText="Digite seu ID" styleClass="login-input" />
                                    </children>
                                </VBox>

                                <VBox spacing="6.0" styleClass="input-group">
                                    <children>
                                        <Label styleClass="field-label" text="PASSWORD" />
                                        <PasswordField fx:id="passwordField" maxWidth="1.7976931348623157E308" promptText="********" styleClass="login-input" />
                                    </children>
                                </VBox>

                                <Button defaultButton="true" maxWidth="1.7976931348623157E308" minHeight="46.0" mnemonicParsing="false" onAction="#onEntrar" styleClass="login-button" text="ENTRAR" />

                                <HBox alignment="CENTER_LEFT" spacing="22.0">
                                    <children>
                                        <Label styleClass="muted-text" text="Esqueceu as credenciais?" />
                                        <Label styleClass="muted-text" text="Acesso Restrito" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                    <padding>
                        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                    </padding>
                </VBox>
            </children>
        </StackPane>
    </children>
</StackPane>
